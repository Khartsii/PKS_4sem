<Window x:Class="LibraryApp.AuthorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление авторами"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Список авторов"
                FontSize="20"
                FontWeight="Bold"
                   HorizontalAlignment="Center"
                Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1"
                x:Name="dgAuthors"
                AutoGenerateColumns="False"
                  IsReadOnly="True"
                SelectionMode="Single"
                Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                        Binding="{Binding Id}"
                        Width="50"/>
                <DataGridTextColumn Header="Имя"
                        Binding="{Binding FirstName}"
                        Width="120"/>
                <DataGridTextColumn Header="Фамилия"
                        Binding="{Binding LastName}"
                        Width="120"/>
                <DataGridTextColumn Header="Дата рождения"
                        Binding="{Binding BirthDate, StringFormat='dd.MM.yyyy'}"
                        Width="120"/>
                <DataGridTextColumn Header="Страна"
                        Binding="{Binding Country}"
                        Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Center">
            <Button Content="Добавить"
                    Width="100"
                    Height="30"
                    Margin="5"
                    Click="BtnAddAuthor_Click"
                    Background="LightGreen"/>
            <Button Content="Редактировать"
                    Width="100"
                    Height="30"
                    Margin="5"
                    Click="BtnEditAuthor_Click"
                    Background="LightYellow"/>
            <Button Content="Удалить"
                    Width="100"
                    Height="30"
                    Margin="5"
                    Click="BtnDeleteAuthor_Click"
                    Background="LightCoral"/>
            <Button Content="Закрыть"
                    Width="100"
                    Height="30"
                    Margin="5"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>