<!-- MainWindow.xaml -->
<Window x:Class="LibraryApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Библиотека"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen">

        <Grid Margin="10">
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <TextBlock Text="Управление библиотекой"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- Панель фильтрации -->
                <Border Grid.Row="1"
                        BorderBrush="Gray"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="10"
                        Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="Фильтр по жанру:"
                                           VerticalAlignment="Center"
                                           Margin="5"/>
                                <ComboBox x:Name="cmbGenreFilter"
                                          Width="150"
                                          Margin="5"
                                          SelectionChanged="CmbGenreFilter_SelectionChanged"/>

                                <TextBlock Text="Фильтр по автору:"
                                           VerticalAlignment="Center"
                                           Margin="5"/>
                                <ComboBox x:Name="cmbAuthorFilter"
                                          Width="150"
                                          Margin="5"
                                          SelectionChanged="CmbAuthorFilter_SelectionChanged"/>

                                <Button Content="Сбросить фильтр"
                                        Width="100"
                                        Margin="5"
                                        Click="BtnResetFilter_Click"/>
                        </StackPanel>
                </Border>

                <!-- DataGrid для списка книг -->
                <DataGrid Grid.Row="2"
                          x:Name="dgBooks"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          Margin="0,0,0,10">
                        <DataGrid.Columns>
                                <DataGridTextColumn Header="ID"
                                                    Binding="{Binding Id}"
                                                    Width="50"/>
                                <DataGridTextColumn Header="Название"
                                                    Binding="{Binding Title}"
                                                    Width="200"/>
                                <DataGridTextColumn Header="Автор"
                                                    Binding="{Binding AuthorName}"
                                                    Width="150"/>
                                <DataGridTextColumn Header="Год"
                                                    Binding="{Binding PublishYear}"
                                                    Width="80"/>
                                <DataGridTextColumn Header="ISBN"
                                                    Binding="{Binding ISBN}"
                                                    Width="120"/>
                                <DataGridTextColumn Header="Жанр"
                                                    Binding="{Binding GenreName}"
                                                    Width="100"/>
                                <DataGridTextColumn Header="В наличии"
                                                    Binding="{Binding QuantityInStock}"
                                                    Width="80"/>
                        </DataGrid.Columns>
                </DataGrid>

                <!-- Панель кнопок -->
                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">
                        <Button x:Name="btnAdd"
                                Content="Добавить книгу"
                                Width="120"
                                Height="30"
                                Margin="5"
                                Click="BtnAdd_Click"
                                Background="LightGreen"/>
                        <Button x:Name="btnEdit"
                                Content="Редактировать"
                                Width="120"
                                Height="30"
                                Margin="5"
                                Click="BtnEdit_Click"
                                Background="LightYellow"/>
                        <Button x:Name="btnDelete"
                                Content="Удалить"
                                Width="120"
                                Height="30"
                                Margin="5"
                                Click="BtnDelete_Click"
                                Background="LightCoral"/>

                        <Button Content="Управление авторами"
                                Width="150"
                                Height="30"
                                Margin="5"
                                Click="BtnManageAuthors_Click"
                                Background="LightBlue"/>
                        <Button Content="Управление жанрами"
                                Width="150"
                                Height="30"
                                Margin="5"
                                Click="BtnManageGenres_Click"
                                Background="LightBlue"/>
                </StackPanel>
        </Grid>
</Window>